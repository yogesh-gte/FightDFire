# Copy to .env and fill real values. Never commit .env.
#   cp .env.example .env

# --- Core ---
DB_USERNAME=root
DB_PASSWORD=changeme
DB_URL=jdbc:mysql://db:3306/womenbesafe?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
APP_BASE_URL=https://fightdfire.chethancodehub.com
# Optional extra WebSocket origins (comma-separated)
WS_ALLOWED_ORIGINS=

# --- JWT (generate a long random string, e.g. openssl rand -base64 48) ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# 7 days in ms (default). Shorten for stricter sessions.
JWT_EXPIRATION_MS=604800000

# --- First admin bootstrap (only when admins table is empty; clear after first login) ---
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Administrator

# --- Mail (Gmail: use an App Password, not the account password) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Razorpay (Dashboard → API Keys). Prefer live keys only on production. ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- SMS (optional; email still sent by SosService when SMS is off) ---
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
# Tier-2 escalation poll interval (ms)
SOS_ESCALATION_CHECK_MS=15000
# Optional override for training certificate PDFs
APP_CERTIFICATES_DIR=
# Show exception cause chain on error.jsp (set false in production)
APP_ERROR_SHOW_DETAILS=true
# Flyway (true in production). Entity DDL still uses Hibernate until full cutover.
FLYWAY_ENABLED=true
JPA_DDL_AUTO=update
